# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Random string used to sign session cookies. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=replace-with-a-long-random-string

# Shared login password for all AVS staff (plain text for now).
AVS_LOGIN_PASSWORD=replace-with-your-password

# ── AI / Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Project DB (Supabase Storage) ─────────────────────────────────────────────
AVS_PROJECT_FINDER_BUCKET=your-bucket-name
AVS_PROJECT_FINDER_OBJECT_PATH=AVS_Project_Database(1).xlsx

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" on your deployed server to enable Secure cookie flag.
# Leave as "development" (or omit) for local dev.
APP_ENV=development
